---
import CourseLayout from '../../../layouts/CourseLayout.astro';
import VideoPlayer from '../../../components/courses/VideoPlayer.astro';
import QuizPlayer from '../../../components/courses/QuizPlayer.astro';
import { sanityClient } from '../../../lib/sanity';
import { ALL_COURSES_QUERY } from '../../../lib/queries';
import { formatDuration } from '../../../lib/utils';
import type { Course, VideoBlock, FileBlock, QuizBlock } from '../../../lib/types';

export async function getStaticPaths() {
  const courses: Course[] = await sanityClient.fetch(ALL_COURSES_QUERY);
  const paths = [];
  for (const course of courses) {
    for (const block of course.blocks) {
      paths.push({
        params: { slug: course.slug, lessonSlug: block.slug },
        props: { course, block },
      });
    }
  }
  return paths;
}

const { course, block } = Astro.props;
const blockIndex = course.blocks.findIndex(b => b.slug === block.slug);
const prevBlock = blockIndex > 0 ? course.blocks[blockIndex - 1] : null;
const nextBlock = blockIndex < course.blocks.length - 1 ? course.blocks[blockIndex + 1] : null;

const isVideo = block.blockType === 'video';
const isFile  = block.blockType === 'file';
const isQuiz  = block.blockType === 'quiz';

// Only write localStorage for video blocks (tracks watch progress)
const lastWatched = isVideo ? {
  courseSlug: course.slug,
  lessonSlug: block.slug,
  courseTitle: course.title,
  lessonTitle: block.title,
  lessonIndex: blockIndex,
  totalLessons: course.blocks.length,
  thumbnail: course.thumbnail,
  coursePath: `/courses/${course.slug}/${block.slug}`,
} : null;

// File type badge colors
const fileTypeColors: Record<string, string> = {
  PDF:  'bg-red-50 text-red-600',
  DOCX: 'bg-blue-50 text-blue-600',
  ZIP:  'bg-amber-50 text-amber-700',
  LINK: 'bg-hallow-purple-muted text-hallow-purple',
};
---

{lastWatched && (
  <script define:vars={{ lastWatched }}>
    try {
      localStorage.setItem('hallowLastWatched', JSON.stringify(lastWatched));
    } catch {
      // Private browsing or storage full — ignore
    }
  </script>
)}

<CourseLayout course={course} currentBlock={block}>

  {isVideo && (
    <>
      <VideoPlayer
        videoProvider={(block as VideoBlock).videoProvider}
        videoId={(block as VideoBlock).videoId}
        title={block.title}
      />

      <div class="px-6 lg:px-10 py-8 max-w-3xl">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-1.5 text-[11px] text-gray-400 mb-6 font-medium">
          <a href="/courses" class="hover:text-hallow-purple transition-colors">Courses</a>
          <span>/</span>
          <a href={`/courses/${course.slug}`} class="hover:text-hallow-purple transition-colors truncate max-w-[160px]">{course.title}</a>
          <span>/</span>
          <span class="text-gray-500 truncate max-w-[140px]">{block.title}</span>
        </div>

        <!-- Meta -->
        <div class="flex items-center gap-3 mb-3">
          <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-gray-300">
            Step {blockIndex + 1} of {course.blocks.length}
          </span>
          <span class="w-1 h-1 rounded-full bg-gray-200"></span>
          <span class="inline-flex items-center gap-1 text-[11px] text-gray-400 font-medium">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            Video · {formatDuration((block as VideoBlock).duration)}
          </span>
        </div>

        <h1 class="text-2xl font-bold text-gray-900 leading-tight mb-4">{block.title}</h1>
        {block.description && (
          <p class="text-gray-500 text-[15px] leading-relaxed mb-8">{block.description}</p>
        )}

        <!-- Downloads -->
        {(block as VideoBlock).downloadableAssets && (block as VideoBlock).downloadableAssets!.length > 0 && (
          <div class="mb-8 p-5 bg-hallow-purple-muted/50 border border-hallow-purple/10 rounded-2xl">
            <h3 class="flex items-center gap-2 text-[13px] font-bold text-gray-900 mb-3">
              <svg class="w-4 h-4 text-hallow-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
              Lesson Downloads
            </h3>
            <div class="flex flex-col gap-2">
              {(block as VideoBlock).downloadableAssets!.map(asset => (
                <a
                  href={asset.url}
                  download
                  class="flex items-center gap-3 px-4 py-3 bg-white rounded-xl hover:shadow-sm border border-gray-100 hover:border-hallow-purple/20 transition-all group"
                >
                  <span class={`text-[11px] font-bold px-2 py-0.5 rounded-lg font-mono shrink-0 ${fileTypeColors[asset.fileType] ?? 'bg-gray-100 text-gray-600'}`}>
                    {asset.fileType}
                  </span>
                  <span class="text-[13px] text-gray-700 group-hover:text-hallow-purple transition-colors flex-1">{asset.title}</span>
                  <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-hallow-purple transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Prev / Next -->
        <div class="flex gap-3 pt-6 border-t border-gray-100">
          {prevBlock ? (
            <a
              href={`/courses/${course.slug}/${prevBlock.slug}`}
              class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 border border-gray-200 text-[13px] font-semibold text-gray-600 rounded-xl hover:border-hallow-purple hover:text-hallow-purple transition-colors"
            >
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
              Previous
            </a>
          ) : <div class="flex-1" />}
          {nextBlock ? (
            <a
              href={`/courses/${course.slug}/${nextBlock.slug}`}
              class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 bg-hallow-purple text-white text-[13px] font-semibold rounded-xl hover:bg-hallow-purple-dark transition-colors"
            >
              Next
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          ) : (
            <a
              href="/courses"
              class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 border border-gray-200 text-[13px] font-semibold text-gray-600 rounded-xl hover:border-hallow-purple hover:text-hallow-purple transition-colors"
            >
              Back to Courses
            </a>
          )}
        </div>
      </div>
    </>
  )}

  {isFile && (
    <div class="px-6 lg:px-10 py-8 max-w-3xl">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-1.5 text-[11px] text-gray-400 mb-6 font-medium">
        <a href="/courses" class="hover:text-hallow-purple transition-colors">Courses</a>
        <span>/</span>
        <a href={`/courses/${course.slug}`} class="hover:text-hallow-purple transition-colors truncate max-w-[160px]">{course.title}</a>
        <span>/</span>
        <span class="text-gray-500 truncate max-w-[140px]">{block.title}</span>
      </div>

      <!-- Meta -->
      <div class="flex items-center gap-3 mb-3">
        <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-gray-300">
          Step {blockIndex + 1} of {course.blocks.length}
        </span>
        <span class="w-1 h-1 rounded-full bg-gray-200"></span>
        <span class="inline-flex items-center gap-1 text-[11px] text-gray-400 font-medium">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          {(block as FileBlock).fileType}{(block as FileBlock).fileSize ? ` · ${(block as FileBlock).fileSize}` : ''}
        </span>
      </div>

      <h1 class="text-2xl font-bold text-gray-900 leading-tight mb-4">{block.title}</h1>
      {block.description && (
        <p class="text-gray-500 text-[15px] leading-relaxed mb-8">{block.description}</p>
      )}

      <!-- File download card -->
      <div class="rounded-2xl border border-gray-100 bg-gray-50 p-8 flex flex-col sm:flex-row items-center gap-6 mb-8">
        <!-- File icon -->
        <div class="w-16 h-16 rounded-2xl bg-white border border-gray-100 shadow-sm flex items-center justify-center shrink-0">
          <svg class="w-8 h-8 text-hallow-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>

        <div class="flex-1 text-center sm:text-left">
          <div class="flex items-center justify-center sm:justify-start gap-2 mb-1">
            <span class={`text-[11px] font-bold px-2 py-0.5 rounded-lg font-mono ${fileTypeColors[(block as FileBlock).fileType] ?? 'bg-gray-100 text-gray-600'}`}>
              {(block as FileBlock).fileType}
            </span>
            {(block as FileBlock).fileSize && (
              <span class="text-[11px] text-gray-400">{(block as FileBlock).fileSize}</span>
            )}
          </div>
          <p class="font-semibold text-gray-900 text-[15px]">{block.title}</p>
        </div>

        <a
          href={(block as FileBlock).fileUrl}
          download
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-hallow-purple text-white text-[13px] font-bold rounded-xl hover:bg-hallow-purple-dark transition-colors shrink-0"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Download
        </a>
      </div>

      <!-- Prev / Next -->
      <div class="flex gap-3 pt-6 border-t border-gray-100">
        {prevBlock ? (
          <a
            href={`/courses/${course.slug}/${prevBlock.slug}`}
            class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 border border-gray-200 text-[13px] font-semibold text-gray-600 rounded-xl hover:border-hallow-purple hover:text-hallow-purple transition-colors"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Previous
          </a>
        ) : <div class="flex-1" />}
        {nextBlock ? (
          <a
            href={`/courses/${course.slug}/${nextBlock.slug}`}
            class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 bg-hallow-purple text-white text-[13px] font-semibold rounded-xl hover:bg-hallow-purple-dark transition-colors"
          >
            Next
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ) : (
          <a
            href="/courses"
            class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 border border-gray-200 text-[13px] font-semibold text-gray-600 rounded-xl hover:border-hallow-purple hover:text-hallow-purple transition-colors"
          >
            Back to Courses
          </a>
        )}
      </div>
    </div>
  )}

  {isQuiz && (
    <div class="px-6 lg:px-10 py-8 max-w-3xl">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-1.5 text-[11px] text-gray-400 mb-6 font-medium">
        <a href="/courses" class="hover:text-hallow-purple transition-colors">Courses</a>
        <span>/</span>
        <a href={`/courses/${course.slug}`} class="hover:text-hallow-purple transition-colors truncate max-w-[160px]">{course.title}</a>
        <span>/</span>
        <span class="text-gray-500 truncate max-w-[140px]">{block.title}</span>
      </div>

      <!-- Meta -->
      <div class="flex items-center gap-3 mb-3">
        <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-gray-300">
          Step {blockIndex + 1} of {course.blocks.length}
        </span>
        <span class="w-1 h-1 rounded-full bg-gray-200"></span>
        <span class="inline-flex items-center gap-1 text-[11px] text-gray-400 font-medium">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          Quiz · {(block as QuizBlock).questions.length} questions
        </span>
      </div>

      <h1 class="text-2xl font-bold text-gray-900 leading-tight mb-2">{block.title}</h1>
      {block.description && (
        <p class="text-gray-500 text-[15px] leading-relaxed mb-6">{block.description}</p>
      )}

      <!-- Passing score notice -->
      <div class="flex items-center gap-2 px-4 py-2.5 bg-hallow-purple-muted/60 border border-hallow-purple/10 rounded-xl mb-6 w-fit">
        <svg class="w-3.5 h-3.5 text-hallow-purple shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-[12px] text-hallow-purple font-semibold">
          {(block as QuizBlock).passingScore ?? 80}% required to pass
        </span>
      </div>

      <!-- Quiz -->
      <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden">
        <QuizPlayer block={block as QuizBlock} />
      </div>

      <!-- Prev / Next -->
      <div class="flex gap-3 pt-6 mt-6 border-t border-gray-100">
        {prevBlock ? (
          <a
            href={`/courses/${course.slug}/${prevBlock.slug}`}
            class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 border border-gray-200 text-[13px] font-semibold text-gray-600 rounded-xl hover:border-hallow-purple hover:text-hallow-purple transition-colors"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Previous
          </a>
        ) : <div class="flex-1" />}
        {nextBlock ? (
          <a
            href={`/courses/${course.slug}/${nextBlock.slug}`}
            class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 bg-hallow-purple text-white text-[13px] font-semibold rounded-xl hover:bg-hallow-purple-dark transition-colors"
          >
            Next
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ) : (
          <a
            href="/courses"
            class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 border border-gray-200 text-[13px] font-semibold text-gray-600 rounded-xl hover:border-hallow-purple hover:text-hallow-purple transition-colors"
          >
            Back to Courses
          </a>
        )}
      </div>
    </div>
  )}

</CourseLayout>
