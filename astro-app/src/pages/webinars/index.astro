---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebinarTabs from '../../components/webinars/WebinarTabs.astro';
import { mockWebinars } from '../../lib/mockData';

const upcoming = mockWebinars.filter(w => w.status === 'upcoming');
const past = mockWebinars.filter(w => w.status === 'past');
---

<BaseLayout title="Webinars" description="Live and recorded webinars for Hallow partners.">

  <!-- Page Header -->
  <div class="bg-surface border-b border-gray-100">
    <div class="px-5 sm:px-10 lg:px-12 py-12">
      <div class="flex items-center gap-2.5 mb-4">
        <span class="w-5 h-px bg-hallow-purple"></span>
        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-400">Webinars</span>
      </div>
      <h1 class="font-serif text-4xl sm:text-5xl text-gray-900 leading-tight mb-3">
        Partner Webinars
      </h1>
      <p class="text-gray-500 text-[15px] max-w-xl leading-relaxed">
        Live sessions, workshops, and recorded replays — all designed to help your community thrive with Hallow.
      </p>
      <div class="flex gap-6 mt-6 pt-6 border-t border-gray-200">
        <div>
          <span class="text-xl font-extrabold text-gray-900">{upcoming.length}</span>
          <span class="text-[12px] text-gray-400 ml-1.5">Upcoming</span>
        </div>
        <div>
          <span class="text-xl font-extrabold text-gray-900">{past.length}</span>
          <span class="text-[12px] text-gray-400 ml-1.5">Recordings</span>
        </div>
      </div>
    </div>
  </div>

  <div class="px-5 sm:px-10 lg:px-12 py-12">
    <WebinarTabs upcoming={upcoming} past={past} />
  </div>
</BaseLayout>
