---
interface Props {
  tag?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { tag, title, description, align = 'left', class: className = '' } = Astro.props;
const alignClasses = align === 'center' ? 'text-center items-center' : 'text-left items-start';
---

<div class={`flex flex-col gap-3 ${alignClasses} ${className}`}>
  {tag && (
    <div class="flex items-center gap-2.5">
      <span class="w-5 h-px bg-hallow-purple"></span>
      <span class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-400">
        {tag}
      </span>
    </div>
  )}
  <h2 class="font-serif text-3xl sm:text-4xl text-gray-900 leading-tight">
    {title}
  </h2>
  {description && (
    <p class="text-gray-500 text-base leading-relaxed max-w-xl">
      {description}
    </p>
  )}
</div>
