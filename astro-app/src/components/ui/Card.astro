---
interface Props {
  class?: string;
  href?: string;
}

const { class: className = '', href } = Astro.props;

const baseClasses = `bg-white rounded-xl shadow-sm border border-gray-100 ${className}`;
---

{href ? (
  <a href={href} class={`${baseClasses} block hover:shadow-md transition-shadow duration-200`}>
    <slot />
  </a>
) : (
  <div class={baseClasses}>
    <slot />
  </div>
)}
