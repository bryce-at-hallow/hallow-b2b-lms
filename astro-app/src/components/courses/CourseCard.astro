---
import { formatDuration } from '../../lib/utils';
import type { Course } from '../../lib/types';

interface Props {
  course: Course;
  index?: number;
}

const { course, index = 0 } = Astro.props;
const totalDuration = course.lessons.reduce((sum, l) => sum + l.duration, 0);
const staggerClass = `stagger-${Math.min(index + 1, 6)}`;
const firstLesson = course.lessons[0];
const href = firstLesson
  ? `/courses/${course.slug}/${firstLesson.slug}`
  : `/courses/${course.slug}`;
---

<a
  href={href}
  class={`group flex flex-col bg-white border border-gray-100 rounded-2xl overflow-hidden hover:border-hallow-purple/30 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 animate-fade-up opacity-0 ${staggerClass}`}
>
  <!-- Thumbnail -->
  <div class="relative overflow-hidden" style="aspect-ratio: 16/10;">
    <img
      src={course.thumbnail}
      alt={course.title}
      class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500"
      loading="lazy"
    />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

    <!-- Play button (appears on hover) -->
    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300">
      <div class="w-11 h-11 rounded-full bg-white/95 shadow-lg flex items-center justify-center">
        <svg class="w-4 h-4 text-hallow-purple ml-0.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </div>
    </div>

    <!-- Category badge -->
    <div class="absolute top-3 left-3">
      <span class="inline-flex items-center px-2.5 py-1 rounded-lg bg-black/40 backdrop-blur-sm text-white text-[11px] font-semibold tracking-wide">
        {course.category}
      </span>
    </div>

    {course.featured && (
      <div class="absolute top-3 right-3">
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-hallow-purple text-white text-[11px] font-semibold">
          <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          Featured
        </span>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5">
    <h3 class="font-semibold text-gray-900 text-[15px] leading-snug mb-2 group-hover:text-hallow-purple transition-colors">
      {course.title}
    </h3>
    <p class="text-gray-400 text-[13px] leading-relaxed line-clamp-2 flex-1 mb-4">
      {course.description}
    </p>

    <!-- Footer meta -->
    <div class="flex items-center gap-4 pt-4 border-t border-gray-50">
      <span class="flex items-center gap-1.5 text-[12px] text-gray-400 font-medium">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        {course.lessons.length} lesson{course.lessons.length !== 1 ? 's' : ''}
      </span>
      <span class="flex items-center gap-1.5 text-[12px] text-gray-400 font-medium">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        {formatDuration(totalDuration)}
      </span>
      <span class="ml-auto flex items-center gap-1 text-[12px] font-semibold text-hallow-purple opacity-0 group-hover:opacity-100 transition-opacity">
        Start
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
        </svg>
      </span>
    </div>
  </div>
</a>
