---
import { formatDuration } from '../../lib/utils';
import type { Course } from '../../lib/types';

interface Props {
  course: Course;
  currentLessonSlug: string;
}

const { course, currentLessonSlug } = Astro.props;
---

<div class="flex flex-col h-full">
  <!-- Course Header -->
  <div class="px-5 pt-5 pb-4 border-b border-gray-100">
    <a
      href="/courses"
      class="inline-flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] text-gray-400 hover:text-hallow-purple transition-colors mb-4"
    >
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/>
      </svg>
      All Courses
    </a>
    <h2 class="font-semibold text-gray-900 text-[13px] leading-snug">{course.title}</h2>
    <p class="text-[11px] text-gray-400 font-medium mt-1">{course.lessons.length} lessons</p>
  </div>

  <!-- Lesson List -->
  <nav class="flex-1 overflow-y-auto py-3">
    {course.lessons.map((lesson, index) => {
      const isActive = lesson.slug === currentLessonSlug;
      return (
        <a
          href={`/courses/${course.slug}/${lesson.slug}`}
          class={`flex items-start gap-3 px-5 py-3.5 group transition-colors ${
            isActive
              ? 'bg-hallow-purple-muted'
              : 'hover:bg-gray-50'
          }`}
        >
          <div class={`w-6 h-6 rounded-full flex items-center justify-center text-[11px] font-bold shrink-0 mt-0.5 transition-colors ${
            isActive
              ? 'bg-hallow-purple text-white'
              : 'bg-gray-100 text-gray-400 group-hover:bg-hallow-purple-muted group-hover:text-hallow-purple'
          }`}>
            {index + 1}
          </div>
          <div class="min-w-0 flex-1">
            <p class={`text-[13px] leading-snug font-medium ${
              isActive ? 'text-hallow-purple' : 'text-gray-700'
            }`}>
              {lesson.title}
            </p>
            <p class="text-[11px] text-gray-400 mt-0.5">{formatDuration(lesson.duration)}</p>
          </div>
          {isActive && (
            <svg class="w-3.5 h-3.5 text-hallow-purple shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          )}
        </a>
      );
    })}
  </nav>
</div>
