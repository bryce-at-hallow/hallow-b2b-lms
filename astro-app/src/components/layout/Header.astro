---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/courses', label: 'Courses' },
  { href: '/webinars', label: 'Webinars' },
  { href: '/resources', label: 'Resources' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
  <div class="px-5 sm:px-10 lg:px-12">
    <div class="flex items-center justify-between h-[68px]">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group shrink-0">
        <svg width="30" height="30" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="28" height="28" rx="8" fill="#6D0EC1"/>
          <path d="M14 4C10.5 4 8 7 8 10.5C8 14 10 16 12 17.5V22C12 23.1 12.9 24 14 24C15.1 24 16 23.1 16 22V17.5C18 16 20 14 20 10.5C20 7 17.5 4 14 4Z" fill="white"/>
        </svg>
        <span class="font-bold text-gray-900 text-[15px] tracking-tight">Hallow</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-0.5">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`relative px-4 py-2 text-sm font-medium transition-colors duration-150 rounded-lg ${
              isActive(link.href)
                ? 'text-hallow-purple'
                : 'text-gray-500 hover:text-gray-900'
            }`}
          >
            {link.label}
            {isActive(link.href) && (
              <span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-4 h-0.5 bg-hallow-purple rounded-full"></span>
            )}
          </a>
        ))}
      </nav>

      <!-- Right: Support CTA + Mobile toggle -->
      <div class="flex items-center gap-3">
        <a
          href="mailto:parishes@hallow.app"
          class="hidden sm:inline-flex items-center gap-1.5 px-3.5 py-1.5 text-xs font-semibold text-hallow-purple bg-hallow-purple-muted hover:bg-hallow-purple-light rounded-full transition-colors"
        >
          Get Support
        </a>
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors"
          aria-label="Toggle navigation"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-gray-100 bg-white px-4 py-3 space-y-1">
    {navLinks.map(link => (
      <a
        href={link.href}
        class={`flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
          isActive(link.href)
            ? 'bg-hallow-purple-muted text-hallow-purple'
            : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
        }`}
      >
        {link.label}
      </a>
    ))}
    <div class="pt-2 pb-1">
      <a
        href="mailto:parishes@hallow.app"
        class="flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-hallow-purple bg-hallow-purple-muted rounded-lg"
      >
        Get Support
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
