            </g>
          </svg>
        </a>

        <!-- Hallow.com nav links -->
        <nav>
          <ul class="flex flex-wrap gap-x-5 gap-y-2">
            {hallowLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener"
                  class="text-[13px] text-gray-400 hover:text-gray-700 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Social icons -->
        <div class="flex items-center gap-4">
          <!-- Facebook -->
          <a href="https://facebook.com/hallowapp" target="_blank" rel="noopener" class="text-gray-400 hover:text-gray-700 transition-colors" aria-label="Facebook">
