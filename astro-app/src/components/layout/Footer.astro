---
const year = new Date().getFullYear();

const hallowLinks = [
  { href: 'https://hallow.com/about/', label: 'About' },
  { href: 'https://hallow.com/press/', label: 'Press' },
  { href: 'https://help.hallow.com', label: 'Help Center' },
  { href: 'https://hallow.com/daily-quote/', label: 'Daily Quote' },
  { href: 'https://jobs.gem.com/hallow', label: 'Jobs', external: true },
  { href: 'https://hallowapp.myshopify.com/', label: 'Merch' },
];
---

<footer class="bg-white border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ── Main footer content ────────────────────────────────────── -->
    <div class="py-10 flex flex-col md:flex-row gap-10 justify-between">

      <!-- Left: Brand + Hallow links + social -->
      <div class="flex flex-col gap-6">
        <!-- Hallow wordmark SVG -->
        <a href="https://hallow.com" target="_blank" rel="noopener" class="block text-gray-900 hover:text-hallow-purple transition-colors w-fit">
          <svg viewBox="0 0 102 24" xmlns="http://www.w3.org/2000/svg" height="20" fill="currentColor" aria-label="Hallow">
