---
import { categoryLabel, formatDate } from '../../lib/utils';
import type { Resource } from '../../lib/types';

interface Props {
  resource: Resource;
  index?: number;
}

const { resource, index = 0 } = Astro.props;
const staggerClass = `stagger-${Math.min(index + 1, 6)}`;

const fileTypeConfig: Record<string, { label: string; color: string; bg: string }> = {
  PDF:  { label: 'PDF',  color: '#DC2626', bg: '#FEF2F2' },
  DOCX: { label: 'DOC',  color: '#2563EB', bg: '#EFF6FF' },
  ZIP:  { label: 'ZIP',  color: '#D97706', bg: '#FFFBEB' },
  PPTX: { label: 'PPT',  color: '#EA580C', bg: '#FFF7ED' },
  LINK: { label: '↗',   color: '#6D0EC1', bg: '#F3E8FF' },
};
const ftc = resource.fileType ? (fileTypeConfig[resource.fileType] ?? { label: resource.fileType, color: '#6B7280', bg: '#F9FAFB' }) : { label: '…', color: '#6B7280', bg: '#F9FAFB' };

const href = resource.resourceType === 'link' && resource.externalUrl
  ? resource.externalUrl
  : resource.file ?? '#';
const isExternal = resource.resourceType === 'link';

const categoryColors: Record<string, string> = {
  'documentation':       'text-blue-600 bg-blue-50',
  'teacher-planning':    'text-emerald-600 bg-emerald-50',
  'educational-content': 'text-amber-600 bg-amber-50',
  'marketing-materials': 'text-hallow-purple bg-hallow-purple-muted',
  'technical-guides':    'text-gray-600 bg-gray-100',
};
const catColor = categoryColors[resource.category] ?? 'text-gray-600 bg-gray-100';
---

<a
  href={href}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
  download={!isExternal ? '' : undefined}
  class={`group flex items-start gap-4 p-5 bg-white border border-gray-100 rounded-2xl hover:border-hallow-purple/30 hover:shadow-md hover:-translate-y-0.5 transition-all duration-250 animate-fade-up opacity-0 ${staggerClass}`}
>
  <!-- File type pill -->
  <div
    class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-bold text-[11px] tracking-wide mt-0.5"
    style={`color: ${ftc.color}; background: ${ftc.bg};`}
  >
    {ftc.label}
  </div>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-semibold text-gray-900 text-[14px] leading-snug group-hover:text-hallow-purple transition-colors line-clamp-1">
        {resource.title}
      </h3>
      <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-hallow-purple transition-colors shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </div>
    <p class="text-gray-400 text-[12px] leading-relaxed line-clamp-2 mt-1 mb-2.5">
      {resource.description}
    </p>
    <span class={`inline-flex items-center px-2 py-0.5 rounded-md text-[11px] font-semibold ${catColor}`}>
      {categoryLabel(resource.category)}
    </span>
  </div>
</a>
