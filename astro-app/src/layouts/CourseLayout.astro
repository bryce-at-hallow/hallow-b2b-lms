---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import LessonList from '../components/courses/LessonList.astro';
import type { Course, CourseBlock } from '../lib/types';

interface Props {
  title?: string;
  course: Course;
  currentBlock: CourseBlock;
}

const { title, course, currentBlock } = Astro.props;
const pageTitle = title ?? `${currentBlock.title} — ${course.title}`;
---

<!doctype html>
<html lang="en" class="bg-white">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/hallow-icon-purple.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle} | Hallow Partner Hub</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 antialiased font-sans">
    <Header />
    <main class="flex-1 flex flex-col lg:flex-row max-w-screen-2xl mx-auto w-full">
      <!-- Sidebar -->
      <aside class="lg:w-80 xl:w-96 lg:min-h-[calc(100vh-64px)] border-r border-gray-100 bg-gray-50 shrink-0">
        <LessonList course={course} currentLessonSlug={currentBlock.slug} />
      </aside>

      <!-- Main Content -->
      <div class="flex-1 min-w-0">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
